---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found — StatRift"
  description="That page doesn't exist. Head back to the StatRift menu and pick a game."
>
  <main class="notFound">
    <h1>404</h1>
    <p>That page slipped into the fog.</p>
    <a href="/" class="link">Return to menu</a>
  </main>
</BaseLayout>

<style>
  .notFound {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    padding: var(--space-7) var(--space-6);
    text-align: center;
  }

  h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(72px, 14vw, 144px);
    font-weight: 700;
    color: var(--color-gold);
    letter-spacing: var(--tracking-display);
    line-height: 1;
  }

  p {
    margin: 0;
    font-size: var(--fs-md);
    color: var(--color-text-dim);
  }

  .link {
    margin-top: var(--space-3);
    padding: var(--space-3) var(--space-5);
    border: 1px solid var(--color-gold-deep);
    border-radius: var(--radius-md);
    font-family: var(--font-display);
    font-size: var(--fs-sm);
    letter-spacing: var(--tracking-display);
    color: var(--color-gold);
    transition:
      background var(--motion-fast) var(--ease-out),
      color var(--motion-fast) var(--ease-out);
  }

  .link:hover {
    background: var(--color-gold);
    color: var(--color-bg-deep);
  }
</style>
