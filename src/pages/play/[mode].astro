---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GameScreen from '../../components/GameScreen/GameScreen.jsx';
import PixelRevealScreen from '../../components/PixelReveal/PixelRevealScreen.jsx';
import { ALL_MODES, isMinigameId } from '../../utils/constants.js';

export function getStaticPaths() {
  return ALL_MODES.map((entry) => ({
    params: { mode: entry.slug },
    props: {
      modeId: entry.id,
      title: entry.pageTitle,
      description: entry.pageDescription,
      heading: entry.pageHeading,
      intro: entry.pageIntro,
      label: entry.label,
      slug: entry.slug,
    },
  }));
}

const { modeId, title, description, heading, intro, label, slug } = Astro.props;
const isMinigame = isMinigameId(modeId);

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'StatRift',
      item: new URL('/', Astro.site).toString(),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: label,
      item: new URL(`/play/${slug}/`, Astro.site).toString(),
    },
  ],
};
---

<BaseLayout title={title} description={description}>
  <main class="page">
    <header class="intro">
      <h1 class="heading">{heading}</h1>
      <p class="lede">{intro}</p>
    </header>

    {
      isMinigame ? (
        <PixelRevealScreen client:only="react" mode={modeId} />
      ) : (
        <GameScreen client:only="react" mode={modeId} />
      )
    }
  </main>

  <script
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbJsonLd)}
  />
</BaseLayout>

<style>
  .page {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .intro {
    max-width: 820px;
    margin: 0 auto;
    padding: var(--space-6) var(--space-6) 0;
    text-align: center;
  }

  .heading {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    letter-spacing: var(--tracking-display);
    color: var(--color-text);
  }

  .lede {
    margin: var(--space-2) 0 0;
    font-size: var(--fs-sm);
    line-height: 1.6;
    color: var(--color-text-dim);
  }

  @media (max-width: 599px) {
    .intro {
      padding: var(--space-4) var(--space-4) 0;
    }
  }
</style>
