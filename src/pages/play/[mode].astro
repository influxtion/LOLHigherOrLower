---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GameScreen from '../../components/GameScreen/GameScreen.jsx';
import PixelRevealScreen from '../../components/PixelReveal/PixelRevealScreen.jsx';
import { ALL_MODES, isMinigameId } from '../../utils/constants.js';

export function getStaticPaths() {
  return ALL_MODES.map((entry) => ({
    params: { mode: entry.slug },
    props: {
      modeId: entry.id,
      title: entry.pageTitle,
      description: entry.pageDescription,
      heading: entry.pageHeading,
      intro: entry.pageIntro,
      label: entry.label,
      slug: entry.slug,
    },
  }));
}

const { modeId, title, description, heading, intro, label, slug } = Astro.props;
const isMinigame = isMinigameId(modeId);

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'StatRift',
      item: new URL('/', Astro.site).toString(),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: label,
      item: new URL(`/play/${slug}/`, Astro.site).toString(),
    },
  ],
};
---

<BaseLayout title={title} description={description}>
  <div class="topbar">
    <h1 class="heading">{heading}</h1>
    <button
      type="button"
      class="infoBtn"
      aria-label="About this game"
      aria-expanded="false"
      aria-controls="mode-intro"
      data-info-toggle
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="16" x2="12" y2="12"></line>
        <line x1="12" y1="8" x2="12.01" y2="8"></line>
      </svg>
    </button>
    <div id="mode-intro" class="infoPanel" role="region" aria-label="About this game" hidden>
      <p>{intro}</p>
    </div>
  </div>

  {
    isMinigame ? (
      <PixelRevealScreen client:only="react" mode={modeId} />
    ) : (
      <GameScreen client:only="react" mode={modeId} />
    )
  }

  <script
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbJsonLd)}
  />
</BaseLayout>

<script>
  const btn = document.querySelector('[data-info-toggle]');
  const panel = document.getElementById('mode-intro');
  if (btn && panel) {
    const close = () => {
      panel.hidden = true;
      btn.setAttribute('aria-expanded', 'false');
    };
    const open = () => {
      panel.hidden = false;
      btn.setAttribute('aria-expanded', 'true');
    };
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      panel.hidden ? open() : close();
    });
    document.addEventListener('click', (e) => {
      if (panel.hidden) return;
      if (panel.contains(e.target) || btn.contains(e.target)) return;
      close();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !panel.hidden) close();
    });
  }
</script>

<style>
  .topbar {
    position: absolute;
    top: var(--space-4);
    left: var(--space-4);
    z-index: 5;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    max-width: calc(100% - var(--space-4) * 2);
  }

  .heading {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--fs-md);
    font-weight: 600;
    letter-spacing: var(--tracking-display);
    color: var(--color-text-dim);
    text-shadow:
      0 0 10px rgba(7, 9, 15, 0.9),
      0 2px 4px rgba(7, 9, 15, 0.8);
  }

  .infoBtn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: rgba(7, 9, 15, 0.6);
    color: var(--color-text-faint);
    transition:
      color var(--motion-fast) var(--ease-out),
      border-color var(--motion-fast) var(--ease-out);
  }

  .infoBtn:hover {
    color: var(--color-gold);
    border-color: var(--color-gold-deep);
  }

  .infoPanel {
    position: absolute;
    top: calc(100% + var(--space-2));
    left: 0;
    max-width: min(360px, calc(100vw - var(--space-6)));
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-panel);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: 0 20px 40px -20px rgba(0, 0, 0, 0.8);
    animation: info-rise var(--motion-fast) var(--ease-out) both;
  }

  @keyframes info-rise {
    from {
      opacity: 0;
      transform: translateY(-4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .infoPanel p {
    margin: 0;
    font-size: var(--fs-sm);
    line-height: 1.6;
    color: var(--color-text-dim);
  }

  @media (max-width: 599px) {
    .topbar {
      top: var(--space-3);
      left: var(--space-3);
    }
    .heading {
      font-size: var(--fs-sm);
    }
  }
</style>
